{
  "manifest_version": 3,
  "name": "Proposal Bot",
  "version": "0.1.0",
  "description": "A Chrome extension starter for Proposal Bot.",
  "action": {
    "default_title": "Proposal Bot",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting"]
}
